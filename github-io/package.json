{
  "name": "a-puzzle-a-day-github-io",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:puzzle-wheel": "cd .. && uv build",
    "sync-puzzle-wheel": "pnpm run build:puzzle-wheel && mkdir -p public/local-puzzle && cp ../dist/cadbuildr_projects_a_puzzle_a_day-*.whl public/local-puzzle/",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@cadbuildr/cad-kernel-r3f": "^0.2.0",
    "@cadbuildr/cad-pyodide-runtime": "^0.1.1",
    "@cadbuildr/sdk-react": "^0.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.490.0",
    "pyodide": "^0.29.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.11.0",
    "react-dom": "^19.2.4",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.14"
